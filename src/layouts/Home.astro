---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import Hr from "@components/Hr.astro";
import Link from "@components/Link.astro";
import Layout from "@layouts/Layout.astro";
import Socials from "@layouts/Socials.astro";
import Experience from "@layouts/Experience.astro";
import Skills from "@layouts/Skills.astro";
import SideProject from "@layouts/SideProject.astro";
import Section from "@layouts/Section.astro";
import Education from "@layouts/Education.astro";

import { type Locale, useTranslations } from "@utils/i18n";
import photo from "../images/photo.jpeg";

export interface Props {
  experiences: CollectionEntry<"experiences">[];
  sideProjects: CollectionEntry<"sideProjects">[];
  educations: CollectionEntry<"educations">[];
  skills: string[];
  selectedSkill?: string;
  locale: Locale;
}

const { experiences, sideProjects, educations, skills, selectedSkill, locale } =
  Astro.props;

const t = useTranslations(locale);
---

<Layout>
  <main class="mx-auto mb-4 max-w-3xl px-4">
    <section class="grid gap-2">
      <div class="grid grid-cols-1 md:grid-cols-5 md:place-items-center gap-4">
        <div class="col-span-4">
          <Link
            href={Astro.site!.toString()}
            size="large"
            class="decoration-green-600"
          >
            <h1
              class="font-headline text-5xl text-green-600 font-bold leading-normal tracking-wide print:text-4xl print:leading-normal"
            >
              Alexis Lucas
            </h1>
          </Link>
          <h2 class="font-headline text-3xl font-bold print:text-3xl">
            {t("home.jobTitle")}
          </h2>
          <p class="leading-tight text-justify">
            {t("home.intro")}
          </p>
        </div>
        <div
          class="flex flex-row-reverse md:flex-col col-span-5 md:col-span-1 justify-center items-center gap-0"
        >
          <Socials class="print:hidden" />

          <Image
            alt={t("home.profileAlt")}
            src={photo}
            width={320}
            height={320}
            fit="cover"
            position="top"
            class="rounded-full border-4 border-green-600 w-24 md:w-32"
          />
        </div>
      </div>
      <Socials class="hidden print:grid" />
    </section>

    <Hr />

    <Section title={t("home.sections.skills")}>
      <p class="text-justify text-slate-700 print:hidden">
        {t("home.skills.hint")}
      </p>
      <Skills active={skills} selected={selectedSkill} locale={locale} />
    </Section>

    {
      experiences.length > 0 && (
        <>
          <Hr />
          <Section title={t("home.sections.experience")}>
            <div class="grid grid-cols-1 gap-4">
              {experiences.map((exp) => (
                <Experience
                  data={exp}
                  selectedSkill={selectedSkill}
                  locale={locale}
                />
              ))}
            </div>
          </Section>
        </>
      )
    }

    {
      sideProjects.length > 0 && (
        <>
          <Hr />
          <Section title={t("home.sections.sideProjects")}>
            <Link href="https://github.com/sixelasacul" slot="subtitle">
              {t("home.seeMoreOnGithub")}
            </Link>
            <div class="grid grid-cols-1 place-items-start gap-4 sm:grid-cols-2">
              {sideProjects.map((project) => (
                <SideProject data={project} selectedSkill={selectedSkill} locale={locale} />
              ))}
            </div>
          </Section>
        </>
      )
    }

    {
      educations.length > 0 && !selectedSkill && (
        <>
          <Hr />
          <Section title={t("home.sections.education")}>
            <div class="grid">
              {educations.map((education) => (
                <Education data={education} locale={locale} />
              ))}
            </div>
          </Section>
        </>
      )
    }
  </main>
</Layout>
